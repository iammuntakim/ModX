{
  "schemaVersion": 1,
  "id": "mods",
  "version": "${version}",

  "name": "Mods",
  "description": "Client utility mod with debug features",
  "authors": ["MUNTAKIM"],

  "contact": {},

  "license": "All-Rights-Reserved",

  "icon": "assets/icon.png",

  "environment": "client",

  "entrypoints": {
    "client": [
      "com.plugin.mods.Main"
    ],
    "modmenu": [
      "com.plugin.mods.ModMenu"
    ]
  },

  "depends": {
    "fabricloader": ">=${loader_version}",
    "minecraft": "${minecraft_version}",
    "fabric": "*",
    "fabric-api": "*"
  },

  "suggests": {
    "modmenu": "*"
  }
}